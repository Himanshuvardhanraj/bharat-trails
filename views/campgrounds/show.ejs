<% layout('layout/boilerplate') %>
<link rel="stylesheet" href="/stylesheets/star.css" />

<div class="row mb-4">
  <div class="col-md-10 mx-auto">
    <div class="card mb-4">
 <% if (campground.images && campground.images.length) { %>
   <% campground.images.forEach(function(img) { %>
    <img src="<%= img.url %>" class="card-img-top" alt="<%= campground.title %>" />
   <% }); %>
<% } else { %>
  <img
    src="https://images.unsplash.com/photo-1506461883276-594a12b11cf3?auto=format&fit=crop&w=1200&q=80"
    class="card-img-top"
    alt="<%= campground.title %>"
  />
<% } %>
      <div class="card-body">
        <h2 class="card-title"><%= campground.title %></h2>
        <p class="card-text"><%= campground.description %></p>
        <div class="row">
          <div class="col-sm-6">
            <p class="mb-1"><strong>Location:</strong> <%= campground.location %></p>
          </div>
          <div class="col-sm-6">
            <p class="mb-1"><strong>submitted by</strong> <%= campground.author.username %></p>
          </div>
          <div class="col-sm-6">
            <p class="mb-1"><strong>Price:</strong> $<%= campground.price %></p>
          </div>
        </div>
        <%if (currentUser && currentUser._id.equals(campground.author._id)) { %>
        <div class="mt-3">
          <a class="btn btn-info me-2" href="/campgrounds/<%= campground._id %>/edit">Edit Campground</a>
          <form class="d-inline" action="/campgrounds/<%= campground._id %>?_method=DELETE" method="POST">
            <button type="submit" class="btn btn-danger">Delete Campground</button>
          </form>
        </div>
        <% } %>
      </div>
      <div class="card-footer text-muted">
        <a href="/campgrounds">All Campgrounds</a>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-md-10 mx-auto">
    <div id="map" style="width: 100%; height: 300px;"></div>
    <div class="d-flex justify-content-between align-items-end mb-3">
      <div>
        <h3 class="mb-0">Reviews</h3>
        <small class="text-muted"><%= reviews.length %> review<%= reviews.length === 1 ? '' : 's' %></small>
      </div>
      <div>
        <a class="btn btn-sm btn-outline-secondary" href="#review-form">Leave a review</a>
      </div>
    </div>

    <% if (reviews.length === 0) { %>
      <div class="review-empty-state mb-4">
        <p class="mb-0">No reviews yet. Be the first to leave feedback for this campground.</p>
      </div>
    <% } else { %>
      <% reviews.forEach(review => { %>
        <div class="card review-card mb-3">
          <div class="card-header d-flex justify-content-between align-items-center">
            <div>
              <strong><%= review.author %></strong>
              <span class="text-muted">• <%= new Date(review.createdAt).toLocaleDateString() %></span>
            </div>
            <span class="badge bg-primary review-rating">Rating: <%= review.rating %>/5</span>
          </div>
          <div class="card-body">
            <p class="card-text"><%= review.body %></p>
            <% if (currentUser && review.authorId && review.authorId.equals(currentUser._id)) { %>
            <form action="/campgrounds/<%= campground._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST" class="d-inline">
              <button type="submit" class="btn btn-sm btn-outline-danger">Delete Review</button>
            </form>
              <% } %>
          </div>
        </div>
      <% }); %>
    <% } %>

    <div id="review-form" class="review-form">
      <h4>Add a review</h4>
      <%- include('../partials/form-errors', { errors: errors }) %>
      <form action="/campgrounds/<%= campground._id %>/reviews" method="POST" novalidate class="validated-form">
        <div class="mb-3">
          <label class="form-label" for="author">Your Name</label>
          <input class="form-control" type="text" id="author" name="review[author]" value="<%= review.author || '' %>" required />
          <div class="valid-feedback">Looks good!</div>
          <div class="invalid-feedback"></div>
        </div>
        <div class="mb-3">
          <label class="form-label" for="rating">Rating</label>
          <select class="form-select" id="rating" name="review[rating]" required>
            <option value="" <%= !review.rating ? 'selected' : '' %>>Choose rating</option>
            <% for (let i = 1; i <= 5; i++) { %>
              <option value="<%= i %>" <%= review.rating == i ? 'selected' : '' %>><%= i %></option>
            <% } %>
          </select>
          <div class="valid-feedback">Looks good!</div>
          <div class="invalid-feedback"></div>
        </div>
        <div class="mb-3">
          <label class="form-label" for="body">Review</label>
          <textarea class="form-control" id="body" name="review[body]" rows="4" required><%= review.body || '' %></textarea>
          <div class="valid-feedback">Looks good!</div>
          <div class="invalid-feedback"></div>
        </div>
        <button class="btn btn-success" type="submit">Submit Review</button>
      </form>
    </div>
  </div>
</div>
<%-"<script>"%>
const maptilerApiKey = '<%- process.env.MAPTILER_API_KEY %>';
const campground = <%- JSON.stringify(campground) %>;
<%-"</script>"%>

<script src="/javascripts/showPageMap.js"></script>