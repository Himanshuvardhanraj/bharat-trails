<% layout('layout/boilerplate')%>
<div class="row">
  <h1 class="text-center">New Campground</h1>
  <div class="col-md-6 offset-md-3">
    <%- include('../partials/form-errors', { errors: errors }) %>
    <form
      action="/campgrounds"
      method="POST"
      novalidate
      class="validated-form"
    >
      <div class="mb-3">
        <label class="form-label" for="title">Title</label>
        <input
          class="form-control"
          type="text"
          id="title"
          name="campground[title]"
          value="<%= campground ? campground.title : '' %>"
          required
        />
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback"></div>
      </div>
      <div class="mb-3">
        <label class="form-label" for="location">Location</label>
        <input
          class="form-control"
          type="text"
          id="location"
          name="campground[location]"
          value="<%= campground ? campground.location : '' %>"
          required
        />
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback"></div>
      </div>
      <div class="mb-3">
        <label class="form-label" for="price">Campground Price</label>
        <div class="input-group">
          <span class="input-group-text" id="price-label">$</span>
          <input
            type="number"
            class="form-control"
            id="price"
            placeholder="0.00"
            aria-label="price"
            aria-describedby="price-label"
            name="campground[price]"
            value="<%= campground ? campground.price : '' %>"
            min="0"
            step="0.01"
            required
          />
        </div>
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback"></div>
      </div>

      <div class="mb-3">
        <label class="form-label" for="description">Description</label>
        <textarea
          class="form-control"
          id="description"
          name="campground[description]"
          required
        ><%= campground ? campground.description : '' %></textarea>
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback"></div>
      </div>
      <div class="mb-3">
        <button class="btn btn-success" type="submit">Add Campground</button>
      </div>
    </form>
    <a href="/campgrounds">All Campgrounds</a>
  </div>
</div>
